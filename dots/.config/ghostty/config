# TODO: dynamic path here
command = /opt/homebrew/bin/fish
font-family = Hack
mouse-hide-while-typing = true

window-decoration = true
macos-non-native-fullscreen = true
auto-update = download

shell-integration-features = no-cursor

theme = Gruvbox Material Dark

# Normal Ghostty pane navigation outside Neovim.
keybind = ctrl+h=goto_split:left
keybind = ctrl+j=goto_split:down
keybind = ctrl+k=goto_split:up
keybind = ctrl+l=goto_split:right

# Neovim mode. The plugin activates this table through AppleScript.
# These bindings send raw Ctrl-h/j/k/l to Neovim instead of running Ghostty actions.
keybind = nvim/
keybind = nvim/ctrl+h=text:\x08
keybind = nvim/ctrl+j=text:\x0a
keybind = nvim/ctrl+k=text:\x0b
keybind = nvim/ctrl+l=text:\x0c
